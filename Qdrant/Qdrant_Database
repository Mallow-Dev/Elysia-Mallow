from abc import ABC, abstractmethod
from typing import List, Dict, Any, Optional
import numpy as np
import os


class VectorDB(ABC):
    """Abstract base class for vector databases."""

    @abstractmethod
    def connect(self, **kwargs):
        pass

    @abstractmethod
    def create_collection(self, name: str, vector_size: int):
        pass

    @abstractmethod
    def insert_vectors(
        self, collection: str, vectors: List[np.ndarray], payloads: List[Dict[str, Any]]
    ):
        pass

    @abstractmethod
    def search_vectors(
        self, collection: str, query_vector: np.ndarray, limit: int = 10
    ) -> List[Dict[str, Any]]:
        pass


class QdrantDB(VectorDB):
    """Qdrant implementation of VectorDB."""

    def __init__(self):
        self.client = None
        self.collections = {}

    def _ensure_client(self):
        if self.client is None:
            raise RuntimeError(
                "Qdrant client is not connected. Call connect() before performing operations."
            )
        return self.client

    def create_collection(self, name: str, vector_size: int):
        from qdrant_client.models import Distance, VectorParams

        client = self._ensure_client()
        client.create_collection(
            collection_name=name,
            vectors_config=VectorParams(size=vector_size, distance=Distance.COSINE),
        )
        self.collections[name] = vector_size

    def insert_vectors(
        self, collection: str, vectors: List[np.ndarray], payloads: List[Dict[str, Any]]
    ):
        from qdrant_client.models import PointStruct

        client = self._ensure_client()
        points = [
            PointStruct(id=i, vector=vector.tolist(), payload=payload)
            for i, (vector, payload) in enumerate(zip(vectors, payloads))
        ]
        client.upsert(collection_name=collection, points=points)

    def search_vectors(
        self, collection: str, query_vector: np.ndarray, limit: int = 10
    ) -> List[Dict[str, Any]]:
        client = self._ensure_client()
        search_result = client.search(
            collection_name=collection, query_vector=query_vector.tolist(), limit=limit
        )
        return [{"payload": hit.payload, "score": hit.score} for hit in search_result]

    def search_vectors(
        self, collection: str, query_vector: np.ndarray, limit: int = 10
    ) -> List[Dict[str, Any]]:
        search_result = self.client.search(
            collection_name=collection, query_vector=query_vector.tolist(), limit=limit
        )
        return [{"payload": hit.payload, "score": hit.score} for hit in search_result]

    def connect(self, **kwargs):
        raise NotImplementedError


